      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"postgres-exporter\"}",
          "legendFormat": "PostgreSQL",
          "refId": "A"
        }
      ]
